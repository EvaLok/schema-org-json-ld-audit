#!/usr/bin/env bash
# Shell wrapper for the audit-journal Rust tool.
# Usage: bash tools/audit-journal <subcommand> [args...]
#
# Looks for a pre-built release binary first (CI fast path),
# then falls back to cargo build if not found.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
BINARY="$SCRIPT_DIR/rust/target/release/audit-journal"

if [ ! -x "$BINARY" ]; then
    echo "Pre-built binary not found, building..." >&2
    cargo build --release --manifest-path "$SCRIPT_DIR/rust/Cargo.toml" >&2
fi

exec "$BINARY" --repo-root "$REPO_ROOT" "$@"
